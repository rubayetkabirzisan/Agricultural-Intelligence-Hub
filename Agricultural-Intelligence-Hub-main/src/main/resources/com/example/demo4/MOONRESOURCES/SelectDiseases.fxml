<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
  SelectDiseases.fxml — Disease Detail Viewer with Sidebar Navigation
  Controller: com.example.demo4.ui.weather.SelectDiseasesController
  All fx:id bindings preserved: name11, name22, name33, name44 (sidebar),
    name1, name2, name3, name4 (content titles),
    lb1, lb2, lb3, lb4 (descriptions),
    imgView1, imgView2, imgView3, imgView4 (images)
  onAction preserved: #onName1Clk, #onName2Clk, #onName3Clk, #onName4Clk, #prevBtn
-->
<BorderPane
    prefWidth="1100.0"
    prefHeight="700.0"
    styleClass="app-root"
    stylesheets="@../styles/application.css"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.example.demo4.ui.weather.SelectDiseasesController">

    <!-- ── TOP BAR ── -->
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="16">
            <Label text="🔬" style="-fx-font-size: 18px;" />
            <Label text="Disease Information" styleClass="text-page-title" />
        </HBox>
    </top>

    <!-- ── LEFT SIDEBAR ── -->
    <left>
        <VBox styleClass="sidebar" spacing="4">
            <padding>
                <Insets top="20" right="12" bottom="20" left="12" />
            </padding>

            <Label text="DISEASES" styleClass="text-small" style="-fx-padding: 0 0 8 4;" />

            <Hyperlink
                fx:id="name11"
                styleClass="nav-hyperlink"
                text="Disease 1"
                onAction="#onName1Clk" />
            <Hyperlink
                fx:id="name22"
                styleClass="nav-hyperlink"
                text="Disease 2"
                onAction="#onName2Clk" />
            <Hyperlink
                fx:id="name33"
                styleClass="nav-hyperlink"
                text="Disease 3"
                onAction="#onName3Clk" />
            <Hyperlink
                fx:id="name44"
                styleClass="nav-hyperlink"
                text="Disease 4"
                onAction="#onName4Clk" />

            <!-- Spacer pushes Back to bottom -->
            <Region VBox.vgrow="ALWAYS" />

            <Button
                text="← Back"
                styleClass="btn-ghost"
                onAction="#prevBtn"
                maxWidth="200"
                mnemonicParsing="false" />
        </VBox>
    </left>

    <!-- ── CENTER: Disease content (scrollable) ── -->
    <center>
        <ScrollPane styleClass="scroll-area" fitToWidth="true">
            <content>
                <VBox spacing="20" style="-fx-padding: 24 32 40 32;">

                    <!-- Disease Entry 1 -->
                    <VBox styleClass="disease-card" spacing="16">
                        <Hyperlink
                            fx:id="name1"
                            styleClass="text-section"
                            text="Disease Name"
                            onAction="#onName1Clk" />
                        <HBox spacing="20" alignment="TOP_LEFT">
                            <Label
                                fx:id="lb1"
                                styleClass="text-body"
                                wrapText="true"
                                HBox.hgrow="ALWAYS" />
                            <ImageView
                                fx:id="imgView1"
                                fitWidth="280"
                                fitHeight="200"
                                preserveRatio="true"
                                pickOnBounds="true">
                                <image>
                                    <Image url="@Rice/bacterial_blight.jpg" />
                                </image>
                            </ImageView>
                        </HBox>
                    </VBox>

                    <!-- Divider -->
                    <Region styleClass="divider" minHeight="1" maxHeight="1" />

                    <!-- Disease Entry 2 -->
                    <VBox styleClass="disease-card" spacing="16">
                        <Hyperlink
                            fx:id="name2"
                            styleClass="text-section"
                            text="Disease Name"
                            onAction="#onName2Clk" />
                        <HBox spacing="20" alignment="TOP_LEFT">
                            <Label
                                fx:id="lb2"
                                styleClass="text-body"
                                wrapText="true"
                                HBox.hgrow="ALWAYS" />
                            <ImageView
                                fx:id="imgView2"
                                fitWidth="280"
                                fitHeight="200"
                                preserveRatio="true"
                                pickOnBounds="true">
                                <image>
                                    <Image url="@Rice/bacterial-leaf-streak.jpg" />
                                </image>
                            </ImageView>
                        </HBox>
                    </VBox>

                    <!-- Divider -->
                    <Region styleClass="divider" minHeight="1" maxHeight="1" />

                    <!-- Disease Entry 3 -->
                    <VBox styleClass="disease-card" spacing="16">
                        <Hyperlink
                            fx:id="name3"
                            styleClass="text-section"
                            text="Disease Name"
                            onAction="#onName3Clk" />
                        <HBox spacing="20" alignment="TOP_LEFT">
                            <Label
                                fx:id="lb3"
                                styleClass="text-body"
                                wrapText="true"
                                HBox.hgrow="ALWAYS" />
                            <ImageView
                                fx:id="imgView3"
                                fitWidth="280"
                                fitHeight="200"
                                preserveRatio="true"
                                pickOnBounds="true">
                                <image>
                                    <Image url="@Rice/blast-leaf-4.jpg" />
                                </image>
                            </ImageView>
                        </HBox>
                    </VBox>

                    <!-- Divider -->
                    <Region styleClass="divider" minHeight="1" maxHeight="1" />

                    <!-- Disease Entry 4 -->
                    <VBox styleClass="disease-card" spacing="16">
                        <Hyperlink
                            fx:id="name4"
                            styleClass="text-section"
                            text="Disease Name"
                            onAction="#onName4Clk" />
                        <HBox spacing="20" alignment="TOP_LEFT">
                            <Label
                                fx:id="lb4"
                                styleClass="text-body"
                                wrapText="true"
                                HBox.hgrow="ALWAYS" />
                            <ImageView
                                fx:id="imgView4"
                                fitWidth="280"
                                fitHeight="200"
                                preserveRatio="true"
                                pickOnBounds="true">
                                <image>
                                    <Image url="@Rice/blast-neck-panicle.jpg" />
                                </image>
                            </ImageView>
                        </HBox>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
