<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>

<VBox prefHeight="800.0" prefWidth="600.0" spacing="10" style="-fx-padding: 10;" xmlns="http://javafx.com/javafx/20.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo4.ui.weather.AskAi">
    <TextArea fx:id="chatHistory" VBox.vgrow="ALWAYS" editable="false" wrapText="true" style="-fx-font-size: 14px;" />
    <HBox spacing="10">
        <TextField fx:id="userInput" HBox.hgrow="ALWAYS" promptText="Ask Agricultural AI..." onAction="#sendMessage" style="-fx-font-size: 14px;"/>
        <Button text="Send" onAction="#sendMessage" defaultButton="true" style="-fx-font-size: 14px; -fx-padding: 5 15;"/>
    </HBox>
</VBox>
