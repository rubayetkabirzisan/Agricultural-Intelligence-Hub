<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
  diseases.fxml — Disease Identification / Crop Selector Screen
  Controller: com.example.demo4.ui.weather.DiseasesController
  All fx:id bindings preserved: comboboxmoon, throwerror
  onAction preserved: #onHomeBtnClk, #findDiseases
  Removed: Blend effects (invalid), hardcoded AnchorPane sizes
-->
<BorderPane
    prefWidth="1100.0"
    prefHeight="700.0"
    styleClass="app-root"
    stylesheets="@../styles/application.css"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.example.demo4.ui.weather.DiseasesController">

    <!-- ── TOP BAR ── -->
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="16">
            <Button
                text="← Home"
                styleClass="btn-ghost"
                onAction="#onHomeBtnClk"
                mnemonicParsing="false" />
            <Label text="🔬" style="-fx-font-size: 18px;" />
            <Label text="Disease Identification" styleClass="text-page-title" />
        </HBox>
    </top>

    <!-- ── CENTER: Crop selector card ── -->
    <center>
        <StackPane>
            <VBox styleClass="auth-card" maxWidth="520" alignment="CENTER" spacing="20">

                <!-- Icon and heading -->
                <Label text="🌾" style="-fx-font-size: 48px;" />
                <Label text="Select Your Crop" styleClass="text-section" />
                <Label
                    text="Choose a crop below to identify common diseases and get treatment recommendations."
                    styleClass="text-muted"
                    wrapText="true"
                    maxWidth="400"
                    alignment="CENTER" />

                <!-- Error label -->
                <Label
                    fx:id="throwerror"
                    styleClass="text-error"
                    wrapText="true"
                    maxWidth="380" />

                <!-- Crop selector -->
                <ComboBox
                    fx:id="comboboxmoon"
                    styleClass="combo-field"
                    promptText="Select a crop..."
                    maxWidth="380" />

                <!-- Action button -->
                <Button
                    text="Find Diseases →"
                    styleClass="btn-primary"
                    onAction="#findDiseases"
                    maxWidth="380"
                    mnemonicParsing="false" />

            </VBox>
        </StackPane>
    </center>

</BorderPane>
