<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
  selectSeassonAndSand.fxml — Season & Soil Quality Selector
  Controller: com.example.demo4.ui.crops.selectSeassonAndSandController
  All fx:id bindings preserved: season, soilquality, showex, Logo, but
  onAction preserved: #onHomeBtnClk, #findcrop
-->
<BorderPane
    prefWidth="1100.0"
    prefHeight="700.0"
    styleClass="app-root"
    stylesheets="@../styles/application.css"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.example.demo4.ui.crops.selectSeassonAndSandController">

    <!-- ── TOP BAR ── -->
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="16">
            <Button
                text="← Home"
                styleClass="btn-ghost"
                onAction="#onHomeBtnClk"
                mnemonicParsing="false" />
            <Label text="🌍" style="-fx-font-size: 18px;" />
            <Label text="Season &amp; Soil Selection" styleClass="text-page-title" />
        </HBox>
    </top>

    <!-- ── CENTER: Centered configuration card ── -->
    <center>
        <StackPane>

            <VBox styleClass="auth-card" maxWidth="500" alignment="CENTER" spacing="20">

                <!-- Hero icon and heading -->
                <Label text="🌱" style="-fx-font-size: 56px;" />
                <Label text="Configure Farm Conditions" styleClass="text-section" />
                <Label
                    text="Select your current season and soil quality to discover the best crops for your farm."
                    styleClass="text-muted"
                    wrapText="true"
                    maxWidth="400"
                    alignment="CENTER" />

                <!-- Season dropdown -->
                <VBox spacing="6" maxWidth="380">
                    <Label text="Growing Season" styleClass="text-muted" />
                    <ComboBox
                        fx:id="season"
                        styleClass="combo-field"
                        promptText="Select season..."
                        maxWidth="10000" />
                </VBox>

                <!-- Soil quality dropdown -->
                <VBox spacing="6" maxWidth="380">
                    <Label text="Soil Quality" styleClass="text-muted" />
                    <ComboBox
                        fx:id="soilquality"
                        styleClass="combo-field"
                        promptText="Select soil quality..."
                        maxWidth="10000" />
                </VBox>

                <!-- Validation / error feedback -->
                <Label
                    fx:id="showex"
                    styleClass="text-error"
                    wrapText="true"
                    maxWidth="380" />

                <!-- Find crops button -->
                <Button
                    text="Find Recommended Crops →"
                    styleClass="btn-primary"
                    onAction="#findcrop"
                    maxWidth="380"
                    mnemonicParsing="false" />

            </VBox>

            <!--
              HIDDEN NODES — required for @FXML controller bindings.
              Do NOT remove. The controller uses:
                • Logo.getScene().getWindow() to obtain the Stage reference in onHomeBtnClk()
                • but for a RotateTransition animation in initialize()
              Setting managed="false" + visible="false" ensures zero layout impact.
            -->
            <ImageView fx:id="Logo" managed="false" visible="false" />
            <Button fx:id="but" managed="false" visible="false" mnemonicParsing="false" />

        </StackPane>
    </center>

</BorderPane>
