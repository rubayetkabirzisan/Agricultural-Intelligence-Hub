<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
  Intercropping.fxml — Intercropping Information Screen
  Controller: com.example.demo4.ui.crops.IntercroppingController
  All fx:id bindings preserved: cropComboBox, intercroppingProcedureLabel
  onAction preserved: #ButtonOk, #OnVideoLinkclk, #onBtnClk
-->
<BorderPane
    prefWidth="1100.0"
    prefHeight="700.0"
    styleClass="app-root"
    stylesheets="@../styles/application.css"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.example.demo4.ui.crops.IntercroppingController">

    <!-- ── TOP BAR ── -->
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="16">
            <Button
                text="← Back"
                styleClass="btn-ghost"
                onAction="#onBtnClk"
                mnemonicParsing="false" />
            <Label text="🌿" style="-fx-font-size: 18px;" />
            <Label text="Intercropping Guide" styleClass="text-page-title" />
        </HBox>
    </top>

    <!-- ── CENTER ── -->
    <center>
        <VBox spacing="20" style="-fx-padding: 32 48 32 48;">

            <!-- Control row: crop selector + buttons -->
            <VBox styleClass="card" spacing="16" maxWidth="700">
                <Label text="Select Companion Crop" styleClass="text-section" />
                <Label
                    text="Choose a crop to see what it grows best alongside and get detailed intercropping procedures."
                    styleClass="text-muted"
                    wrapText="true" />
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <ComboBox
                        fx:id="cropComboBox"
                        styleClass="combo-field"
                        promptText="Select a crop to intercrop..."
                        HBox.hgrow="ALWAYS" />
                    <Button
                        text="Show Guide"
                        styleClass="btn-primary"
                        onAction="#ButtonOk"
                        mnemonicParsing="false" />
                    <Button
                        text="▶ Watch Video"
                        styleClass="btn-secondary"
                        onAction="#OnVideoLinkclk"
                        mnemonicParsing="false" />
                </HBox>
            </VBox>

            <!-- Procedure content (scrollable) -->
            <ScrollPane styleClass="scroll-area" fitToWidth="true" VBox.vgrow="ALWAYS">
                <content>
                    <VBox style="-fx-padding: 4;">
                        <Label
                            fx:id="intercroppingProcedureLabel"
                            styleClass="text-body"
                            wrapText="true"
                            style="-fx-line-spacing: 4; -fx-padding: 0 0 40 0;" />
                    </VBox>
                </content>
            </ScrollPane>

        </VBox>
    </center>

</BorderPane>
