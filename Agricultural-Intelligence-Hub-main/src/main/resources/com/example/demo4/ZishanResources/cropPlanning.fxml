<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
  cropPlanning.fxml — Crop Planning Results Screen
  Controller: com.example.demo4.ui.crops.cropPlanningController
  All fx:id bindings preserved: label1, label2, season, soilQuality,
    name1, name2, frst, Sec, imageView1, imageView2
  onAction preserved: #onbackbtnclk, #name1clk, #name2clk,
    #onimg1clk, #onimg2clk, #interCropingBtn1, #interCropingBtn2
  CRITICAL FIX: Removed hardcoded ../../../Downloads/ image path
-->
<BorderPane
    prefWidth="1100.0"
    prefHeight="700.0"
    styleClass="app-root"
    stylesheets="@../styles/application.css"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.example.demo4.ui.crops.cropPlanningController">

    <!-- ── TOP BAR ── -->
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="16" fx:id="label1">
            <Button
                text="← Back"
                styleClass="btn-ghost"
                onAction="#onbackbtnclk"
                mnemonicParsing="false" />
            <Label text="🌱" style="-fx-font-size: 18px;" />
            <Label text="Crop Planning Results" styleClass="text-page-title" />
            <Region HBox.hgrow="ALWAYS" />
            <!-- Season and Soil quality badges -->
            <Label fx:id="season" styleClass="badge-success" />
            <Label fx:id="soilQuality" styleClass="badge-info" />
        </HBox>
    </top>

    <!-- ── CENTER: Crop cards (scrollable) ── -->
    <center>
        <ScrollPane styleClass="scroll-area" fitToWidth="true">
            <content>
                <VBox spacing="20" style="-fx-padding: 24 32 40 32;" fx:id="label2">

                    <!-- Crop Card 1 -->
                    <VBox styleClass="card" spacing="16">
                        <Hyperlink
                            fx:id="name1"
                            styleClass="text-section"
                            text="Crop 1"
                            onAction="#name1clk" />
                        <HBox spacing="20" alignment="TOP_LEFT">
                            <!-- Description text -->
                            <Label
                                fx:id="frst"
                                styleClass="text-body"
                                wrapText="true"
                                HBox.hgrow="ALWAYS" />
                            <!-- Crop image — click triggers detail view -->
                            <ImageView
                                fx:id="imageView1"
                                fitWidth="260"
                                fitHeight="200"
                                preserveRatio="true"
                                pickOnBounds="true"
                                onMouseClicked="#onimg1clk" />
                        </HBox>
                        <Button
                            text="🌿 View Intercropping Options"
                            styleClass="btn-secondary"
                            onAction="#interCropingBtn1"
                            mnemonicParsing="false" />
                    </VBox>

                    <!-- Divider -->
                    <Region styleClass="divider" minHeight="1" maxHeight="1" />

                    <!-- Crop Card 2 -->
                    <VBox styleClass="card" spacing="16">
                        <Hyperlink
                            fx:id="name2"
                            styleClass="text-section"
                            text="Crop 2"
                            onAction="#name2clk" />
                        <HBox spacing="20" alignment="TOP_LEFT">
                            <Label
                                fx:id="Sec"
                                styleClass="text-body"
                                wrapText="true"
                                HBox.hgrow="ALWAYS" />
                            <ImageView
                                fx:id="imageView2"
                                fitWidth="260"
                                fitHeight="200"
                                preserveRatio="true"
                                pickOnBounds="true"
                                onMouseClicked="#onimg2clk" />
                        </HBox>
                        <Button
                            text="🌿 View Intercropping Options"
                            styleClass="btn-secondary"
                            onAction="#interCropingBtn2"
                            mnemonicParsing="false" />
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
