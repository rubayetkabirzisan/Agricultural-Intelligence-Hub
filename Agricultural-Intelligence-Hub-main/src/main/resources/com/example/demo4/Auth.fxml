<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
  Auth.fxml — Login & Registration Screen
  Controller: com.example.demo4.ui.auth.AuthController
  All fx:id and onAction bindings are 100% preserved from original.
  Layout changed from fixed VBox to centered card on dark background.
-->
<StackPane
    prefWidth="900.0"
    prefHeight="620.0"
    styleClass="app-root"
    stylesheets="@styles/application.css"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.example.demo4.ui.auth.AuthController">

    <!-- Centered auth card -->
    <VBox styleClass="auth-card" maxWidth="440" alignment="CENTER" spacing="20">

        <!-- ── Logo Row ── -->
        <HBox alignment="CENTER" spacing="10">
            <Label text="🌿" style="-fx-font-size: 32px;" />
            <Label text="Agri-Hub" styleClass="text-app-title" />
        </HBox>

        <!-- ── Subtitle ── -->
        <Label text="Sign in to manage your farm" styleClass="text-muted" />

        <!-- ── Error Label (hidden until needed) ── -->
        <Label
            fx:id="errorLabel"
            styleClass="text-error"
            wrapText="true"
            maxWidth="360"
            alignment="CENTER" />

        <!-- ── Tabs: Login / Register ── -->
        <TabPane
            styleClass="auth-tabs"
            tabClosingPolicy="UNAVAILABLE"
            VBox.vgrow="ALWAYS">

            <!-- LOGIN TAB -->
            <Tab text="Sign In">
                <content>
                    <VBox alignment="CENTER" spacing="14">
                        <padding>
                            <Insets top="24" right="0" bottom="8" left="0" />
                        </padding>
                        <TextField
                            fx:id="loginEmailField"
                            styleClass="field-input"
                            promptText="Email address"
                            maxWidth="360" />
                        <PasswordField
                            fx:id="loginPasswordField"
                            styleClass="field-password"
                            promptText="Password"
                            maxWidth="360" />
                        <Button
                            fx:id="loginBtn"
                            styleClass="btn-primary"
                            text="Sign In"
                            maxWidth="360"
                            onAction="#handleLogin"
                            defaultButton="true" />
                    </VBox>
                </content>
            </Tab>

            <!-- REGISTER TAB -->
            <Tab text="Create Account">
                <content>
                    <VBox alignment="CENTER" spacing="14">
                        <padding>
                            <Insets top="24" right="0" bottom="8" left="0" />
                        </padding>
                        <TextField
                            fx:id="regEmailField"
                            styleClass="field-input"
                            promptText="Email address"
                            maxWidth="360" />
                        <PasswordField
                            fx:id="regPasswordField"
                            styleClass="field-password"
                            promptText="Create password"
                            maxWidth="360" />
                        <Button
                            fx:id="regBtn"
                            styleClass="btn-primary"
                            text="Create Account"
                            maxWidth="360"
                            onAction="#handleRegister" />
                    </VBox>
                </content>
            </Tab>

        </TabPane>

        <!-- ── Footer ── -->
        <Label text="Agricultural Intelligence Hub v1.0" styleClass="text-small" />

    </VBox>
</StackPane>
